{
  "name": "@scale/shared",
  "version": "0.1.0",
  "description": "Código común entre las apps Scale: chat cross-app, registro de apps, conectores BYOK.",
  "type": "module",
  "exports": {
    "./chat": { "types": "./src/chat/index.d.ts", "default": "./src/chat/index.js" },
    "./chat/lib": "./src/chat/data.js",
    "./chat/commands": "./src/chat/commands.js",
    "./registry": { "types": "./src/registry/index.d.ts", "default": "./src/registry/index.js" },
    "./connectors": { "types": "./src/connectors/index.d.ts", "default": "./src/connectors/index.js" },
    "./ia": { "types": "./src/ia/index.d.ts", "default": "./src/ia/index.js" }
  },
  "files": [
    "src"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "lucide-react": ">=0.3"
  },
  "peerDependenciesMeta": {
    "lucide-react": { "optional": false }
